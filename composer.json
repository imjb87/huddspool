{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "althinect/filament-spatie-roles-permissions": "^3.2",
        "awobaz/compoships": "^2.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "daacreators/creators-ticketing": "^1.1.8",
        "doctrine/dbal": "^4.4",
        "eslam-reda-div/filament-copilot": "^1.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "guzzlehttp/guzzle": "^7.2",
        "itsgoingd/clockwork": "^5.1",
        "laravel/framework": "^12.0",
        "laravel/pulse": "^1.2",
        "laravel/reverb": "^1.5",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.9",
        "laravel/tinker": "^2.7",
        "livewire/livewire": "^4.0",
        "minishlink/web-push": "^9.0",
        "pusher/pusher-php-server": "^7.2",
        "sentry/sentry-laravel": "^4.13",
        "silviolleite/laravelpwa": "^2.0",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^6.10",
        "spatie/laravel-responsecache": "^8.3",
        "spatie/laravel-sitemap": "^8.1",
        "stechstudio/filament-impersonate": "^5.0",
        "symfony/brevo-mailer": "^8.0",
        "symfony/http-client": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/boost": "^2.3",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^13.0",
        "spatie/laravel-ignition": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": ["PKSA-yb9k-ykqx-p2zw"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
